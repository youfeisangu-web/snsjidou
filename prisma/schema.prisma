// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Setting {
  id                  Int      @id @default(1)
  threadsUserId       String?
  threadsAccessToken  String?
  geminiApiKey        String?
  imgbbApiKey         String?
  rssUrl              String?  // RSS自動投稿用URL
  hpUrl               String?  // 対象サイトURL
  aiPrompt            String?  // システムプロンプトや前提条件
  implementedFeatures String?  // 実装済みの機能
  upcomingFeatures    String?  // 開発中・予定の機能
  relatedTopics       String?  // 関連項目・リサーチテーマ
  updatedAt           DateTime @updatedAt
}

model Profile {
  id                  String   @id @default(cuid())
  name                String   @default("My Account")
  threadsUserId       String?
  threadsAccessToken  String?
  threadsTokenExpiresAt DateTime? // 60-day expiration tracking
  rssUrl              String?  
  hpUrl               String?  
  aiPrompt            String?  
  aiLearnedInsights   String?
  aiPreferenceRules   String?  @default("")
  successFactors      String?  @default("")
  implementedFeatures String?  
  upcomingFeatures    String?  
  relatedTopics       String?  
  postCountPerDay     Int      @default(3)
  postIntervalType    String   @default("uniform") // "uniform", "random"
  postLength          String   @default("normal") // "long", "short", "normal", "random"
  postStartHour       Int      @default(9)  // 投稿時間帯の開始時刻（JST）
  postEndHour         Int      @default(21) // 投稿時間帯の終了時刻（JST）
  useImageWarehouse   Boolean  @default(false)
  autoCreateDeficientPosts Boolean @default(true)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  posts               Post[]
  insights            PageInsight[]
  images              ImageAsset[]
  templates           PostTemplate[]
}

model PostTemplate {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String   // テンプレート名 (例: "衝撃の事実スレッド型")
  examplePost String   // 参考例文（バズった投稿をそのままコピペ）
  memo        String?  // メモ（なぜ良いか、使いどころ等）
  isActive    Boolean  @default(true)
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
}

model ImageAsset {
  id          String   @id @default(cuid())
  url         String
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  usedCount   Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
}


model Post {
  id          String   @id @default(cuid())
  content     String
  imageUrl    String?  // GCS or ImgBB image URL
  platform    String   @default("threads") // 'threads'
  status      String   @default("draft") // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt DateTime?
  isRss       Boolean  @default(false) // RSSから自動生成されたか
  threadsId   String?  // Threads Post ID
  publishedAt DateTime?
  errorLog    String?  // エラー原因を保存する用

  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  insights     PostInsight[]
}

model PostInsight {
  id           String   @id @default(cuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  impressions  Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0) // replies for Threads
  shares       Int      @default(0) // reposts/quotes for Threads
  
  recordedAt   DateTime @default(now())
}

model PageInsight {
  id                String   @id @default(cuid())
  platform          String   // "facebook"
  
  profileId         String?
  profile           Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  date              DateTime // 計測日
  followers         Int      @default(0)
  postImpressions   Int      @default(0) // period
  pageViews         Int      @default(0) // period

  recordedAt        DateTime @default(now())
}
